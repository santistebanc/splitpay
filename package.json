{
  "name": "splitpay",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:web": "bash scripts/dev.sh web",
    "dev:android": "bash scripts/dev.sh android",
    "dev:ios": "bash scripts/dev.sh ios",
    "dev:tunnel": "bash scripts/dev.sh tunnel",
    "web:build": "npm --workspace apps/mobile run export:web",
    "web:preview": "bash scripts/dev-local.sh",
    "web:watch": "npm --workspace apps/mobile run watch:web",
    "deploy:supabase": "bash supabase/deploy.sh",
    "test": "npm --workspace apps/mobile run test",
    "typecheck": "npm --workspaces run typecheck",
    "lint": "npm --workspaces run lint"
  }
}
