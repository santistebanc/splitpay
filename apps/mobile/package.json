{
  "name": "@splitpay/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "NODE_OPTIONS=--max-old-space-size=4096 expo export --platform web --output-dir dist && node scripts/fix-web-import-meta.mjs && cp public/favicon.ico dist/favicon.ico",
    "serve:web": "npm run export:web && python3 -m http.server 8082 --directory dist --bind 0.0.0.0",
    "watch:web": "node scripts/watch-web.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@journeyapps/wa-sqlite": "^1.7.0",
    "@powersync/adapter-sql-js": "^0.0.18",
    "@powersync/react-native": "^1.35.3",
    "@powersync/web": "^1.38.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.0",
    "@react-navigation/native-stack": "^7.17.1",
    "@supabase/supabase-js": "^2.108.1",
    "@types/react": "~19.1.10",
    "base64-js": "^1.5.1",
    "expo": "~54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.8",
    "lucide-react-native": "^1.17.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.15.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2",
    "vitest": "^2.1.9"
  }
}
